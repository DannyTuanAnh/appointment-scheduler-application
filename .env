# Environment variables for database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=scheduler-app
DB_USER=postgres
DB_PASSWORD=1
DB_SSLMODE=disable

# Environment variables for redis
REDIS_PASSWORD=1

# Environment variables for server
PORT=8080
SV_READTIMEOUT=5
SV_READHEADERTIMEOUT=3
SV_WRITETIMEOUT=10
SV_IDLETIMEOUT=120
SV_SHUTDOWNTIMEOUT=5
SV_MAXHEADERBYTES=16

# Path
PATH_LOGGER=./logs/app.log

